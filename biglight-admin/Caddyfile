# Caddyfile — reverse proxy + HTTPS tự động cho BIGLIGHT Job
#
# Caddy tự xin chứng chỉ HTTPS (Let's Encrypt) và tự gia hạn — không cần certbot.
# Yêu cầu: tên miền đã trỏ bản ghi A về IP VPS, và cổng 80/443 mở.
#
# Cách dùng (Caddy cài trực tiếp trên VPS):
#   1. Đổi your-domain.com bên dưới thành tên miền thật.
#   2. Chép file này tới /etc/caddy/Caddyfile
#   3. sudo systemctl reload caddy
#
# App chạy bằng docker-compose, expose cổng 3000 ra host (xem docker-compose.yml).

job.biglight.jp {
	encode gzip
	reverse_proxy 127.0.0.1:3000
}
