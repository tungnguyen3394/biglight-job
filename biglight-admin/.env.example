# Copy this file to ".env" and fill in real values. NEVER commit ".env".

# ---- Database (PostgreSQL) ----
# Local Docker (xem docker-compose.yml):
DATABASE_URL="postgresql://biglight_job_user:biglight_job_2026@localhost:5432/biglight_job_db?schema=public"

# ---- Session JWT ----
# Bí mật để ký session JWT. Tạo chuỗi ngẫu nhiên dài:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="biglight_job_jwt_secret_key_2026_change_me"
SESSION_HOURS="12"

# ---- Google OAuth ----
# Tạo tại Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Bản client (trình duyệt) cần biến public:
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
